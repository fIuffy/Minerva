{
  "realm": "statefed",
  "enabled": true,
  "displayName": "StateFed Identity Federation (lab)",
  "accessTokenLifespan": 300,
  "sslRequired": "none",
  "clients": [
    {
      "clientId": "tier2-portal",
      "name": "Tier 2 State Citizen Portal (high assurance)",
      "description": "Confidential service client. Holds a client secret on the dual-homed portal — compromising the portal yields this identity and rides the federation path to Tier 1 (T1550, §5.3 #4).",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "tier2-portal-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "fullScopeAllowed": false,
      "protocolMappers": [
        {
          "name": "tier1-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "tier1-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "assurance-high",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "assurance",
            "claim.value": "high",
            "jsonType.label": "String",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "state-clerk",
      "name": "State clerk workstation (standard assurance)",
      "description": "Control identity. Requests a Tier 1 token but only carries assurance=standard, so the federation checkpoint REJECTS it (403). Demonstrates the policy boundary is real, not cosmetic.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "state-clerk-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "fullScopeAllowed": false,
      "protocolMappers": [
        {
          "name": "tier1-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "tier1-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "assurance-standard",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "assurance",
            "claim.value": "standard",
            "jsonType.label": "String",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    }
  ]
}
