# =============================================================================
# Minerva Lab — environment configuration
# Copy to .env and adjust. NEVER commit a real .env (see .gitignore).
#
# Attacking the Playbook — Cross-Framework Coverage Gap Analysis (ATT&CK / ATLAS)
# Undergraduate security-research lab
#
# All values below are for a SELF-OWNED, NETWORK-ISOLATED research lab.
# Credentials here are deliberately weak: they are part of the attack surface
# under study, not secrets to protect. Do not reuse outside this lab. (§7)
# =============================================================================

# ---- Project ----------------------------------------------------------------
COMPOSE_PROJECT_NAME=minerva-lab

# ---- Tier 1: Postgres (citizen records, relational) + pgvector (vector store)-
# Postgres doubles as the relational target (SQLi, T1190) and the RAG vector DB.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=statedata
POSTGRES_USER=portal_svc
POSTGRES_PASSWORD=portal_svc_pw
# pgvector embedding dimension — MUST match EMBED_MODEL output below.
# nomic-embed-text => 768 · mxbai-embed-large => 1024 · all-minilm => 384
EMBED_DIM=768

# ---- MySQL: document store (RAG ingestion source, dual-role data layer) ------
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=docstore
MYSQL_USER=docstore_svc
MYSQL_PASSWORD=docstore_svc_pw
MYSQL_ROOT_PASSWORD=docstore_root_pw

# ---- Federation broker (Keycloak, OIDC) -------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=statefed
# OIDC client the Tier 2 portal uses to obtain Tier 1 access tokens.
# Compromising the dual-homed portal exposes this secret — the "riding
# federated trust to Tier 1" chain (§5.3 #4, T1550 analogue).
KEYCLOAK_CLIENT_ID=tier2-portal
KEYCLOAK_CLIENT_SECRET=tier2-portal-secret
KEYCLOAK_BASE_URL=http://keycloak:8080

# ---- AI inference (Category B local model via Ollama) -----------------------
# In the real lab this is the RTX 4050 laptop reached over the Tailscale mesh:
#   OLLAMA_BASE_URL=http://<laptop-tailnet-ip>:11434
# For single-host dev standup, point at the Docker host:
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Generation model under prompt-injection study (pin name+digest for repro, §9)
GEN_MODEL=llama3
# Embedding model for RAG retrieval (must agree with EMBED_DIM above)
EMBED_MODEL=nomic-embed-text
# Deterministic decoding for reproducible Category-B output (§9 nondeterminism)
GEN_TEMPERATURE=0
GEN_SEED=42

# ---- Samba AD DC fallback (docker-compose.ad.yml) ---------------------------
# Documented Windows-AD fallback per §2.7. Real lab prefers genuine Windows
# Server 2022 AD on a Vultr node; this Linux container is the timeboxed cut.
AD_DOMAIN=STATEFED.LAB
AD_REALM=STATEFED.LAB
AD_ADMIN_PASSWORD=Sup3rS3cret-Admin!
# Kerberoastable service account (SPN set, deliberately weak password) — T1558
AD_SVC_ACCOUNT=svc_sql
AD_SVC_PASSWORD=Summer2026
AD_SVC_SPN=MSSQLSvc/statedata.statefed.lab:1433
# DCSync-capable privileged account — T1003.006 / T1110
AD_DCSYNC_ACCOUNT=backup_admin
AD_DCSYNC_PASSWORD=Backup-Adm1n-2026

# ---- AI-assisted attack harness (harness/) ----------------------------------
# The harness runs on the HOST (the researcher is the executor, §4). It targets
# ONLY the lab; lab.py enforces this allowlist (containment, §7).
LAB_BASE_URL=http://127.0.0.1:8088
# Extra lab hosts when driving the real mesh (e.g. tailnet IP / DC). Comma-sep.
LAB_ALLOWED_HOSTS=
# Category B (local) — harness reaches Ollama on the host, not host.docker.internal
OLLAMA_URL=http://127.0.0.1:11434
# Category A (commercial / guardrailed) — CLOUD APIs. Copilot/Gemini cannot run
# locally; the lab calls out to them. Leave blank if not using Category A.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1   # set to your Azure endpoint if used
